# ============================================
# Production Environment Variables
# ============================================
# Copy relevant values to each platform:
#   - Render: backend env vars
#   - Vercel: frontend env vars (VITE_ prefix)
# ============================================

# === Neon PostgreSQL ===
# Get these from: https://console.neon.tech → your project → Connection Details
# Async (FastAPI) — use postgresql+asyncpg:// prefix
DATABASE_URL=postgresql+asyncpg://USER:PASS@ep-xxx-yyy-zzz.us-east-2.aws.neon.tech/neondb?sslmode=require
# Sync (Alembic/Celery) — use postgresql:// prefix
SYNC_DATABASE_URL=postgresql://USER:PASS@ep-xxx-yyy-zzz.us-east-2.aws.neon.tech/neondb?sslmode=require

# === Redis (optional — leave empty for sync task execution) ===
# Upstash free tier: https://console.upstash.com
# Use rediss:// (double-s) for TLS
REDIS_URL=rediss://default:PASS@xxx.upstash.io:6379

# === Auth ===
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=generate-a-strong-random-key-here

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# === ChromaDB ===
# "ephemeral" for Render (in-memory), "persistent" for local dev
CHROMADB_MODE=ephemeral

# === Fathom API ===
FATHOM_API_KEY=fth_...
FATHOM_API_BASE_URL=https://api.fathom.ai/external/v1
FATHOM_WEBHOOK_SECRET=

# === CORS (set on Render) ===
# Your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app

# === Frontend (set on Vercel) ===
# Your Render backend URL
VITE_API_URL=https://cs-control-plane-api.onrender.com/api
VITE_WS_URL=wss://cs-control-plane-api.onrender.com/api/ws
