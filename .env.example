# Database (Neon — get URLs from https://console.neon.tech → Connection Details)
# Async (FastAPI) — use postgresql+asyncpg:// prefix
DATABASE_URL=postgresql+asyncpg://USER:PASS@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Sync (Alembic/Celery) — use postgresql:// prefix
SYNC_DATABASE_URL=postgresql://USER:PASS@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis (optional — leave empty for sync task execution)
REDIS_URL=

# Auth
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ChromaDB
CHROMADB_PATH=./chromadb_data
CHROMADB_MODE=persistent

# Fathom API (get from https://fathom.video/settings/integrations)
FATHOM_API_KEY=fth_...
FATHOM_API_BASE_URL=https://api.fathom.ai/external/v1
FATHOM_WEBHOOK_SECRET=

# Demo Mode (enables rich terminal logging + demo API endpoint)
DEMO_MODE=true

# Jira (Atlassian Cloud — get token from https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_URL=https://hivepro.atlassian.net
JIRA_EMAIL=your-email@hivepro.com
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=
JIRA_DEFAULT_PROJECT=CS
JIRA_SYNC_JQL=

# Slack (set SLACK_ENABLED=true + bot token to activate notifications)
SLACK_BOT_TOKEN=
SLACK_ALERT_CHANNEL=#cs-alerts
SLACK_ENABLED=false
SLACK_SIGNING_SECRET=
SLACK_CHAT_CHANNEL=
SLACK_BOT_USER_ID=

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/api/ws
